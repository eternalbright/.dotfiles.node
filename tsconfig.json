{
  "extends": "@tsconfig/node-lts-strictest",
  "compilerOptions": {
    "lib": [
        "ESNext"
    ],
    "strict": true,
    "outDir": "../../../dist",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "forceConsistentCasingInFileNames": true,
    "exactOptionalPropertyTypes": true,
    "resolveJsonModule": true
  }
}
